{
  "$schema": "Vafrum Command Payload Test Vectors v1",
  "_meta": {
    "source": "apps/vafrum-bridge/src-tauri/src/lib.rs:1200-1568",
    "extracted_at": "2026-05-04",
    "purpose": "Reference vectors for TS-Builder + Rust-Match snapshot tests in Phase C",
    "known_quirks": {
      "sequence_id_strategies": {
        "default": "0 — used for {print:{...}} commands ohne weitere Felder",
        "led_payload": "0 + root user_id '1234567890' — alle ledctrl-Commands (chamber/work/heatbed light, ledFlashing)",
        "gcode_payload": "2006 + root user_id '1234567890' — gcode_line, nozzleTemp, nozzle2Temp, bedTemp, partFan, auxFan, chamberFan"
      },
      "evaluation_pending": "Diese Inkonsistenzen sind möglicherweise Bambu-Studio-Konvention (firmware-erwartete Werte) oder Legacy-Bugs. Klärung erst nach Hardware-Trace gegen echten Drucker — bis dahin festschreiben wie Rust es tut."
    },
    "sequence_id_strategy": "see known_quirks.sequence_id_strategies",
    "not_implemented_in_rust": [
      "move (im PrinterCommand-Union deklariert, kein Rust-Builder-Branch)",
      "upgradeStart / upgradeConfirm / upgradeConsistencyConfirm (explizit _blocked)",
      "pushall / pushAll (außerhalb des Builders erzeugt — vafrum-mqtt-client/src/mqtt/commands.ts:49 und vafrum-core-api/src/gateway/cloud-mqtt.service.ts:501)"
    ],
    "topic_for_all_payloads": "device/<serial>/request"
  },
